# ─── Core ───────────────────────────────────────────────────────────────────
SECRET_KEY=django-insecure-change-me-in-production

# Set to "False" in production
DEBUG=True

# Comma-separated, e.g. "myapp.railway.app,localhost"
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database (Railway fills DATABASE_URL automatically) ─────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shift_db

# Or fill individual vars for local dev:
POSTGRES_DB=shift_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
PGHOST=localhost
PGPORT=5432

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# ─── Email (leave blank to use console backend in DEBUG mode) ────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@shift.ai
